{
  "name": "international-student-crm-backend",
  "version": "1.0.0",
  "description": "Backend API for International Student CRM System",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "migrate": "psql -h localhost -U postgres -d international_crm -f ../database/schema.sql",
    "seed": "ts-node src/seeds/index.ts",
    "test": "jest"
  },
  "keywords": [
    "crm",
    "education",
    "recruitment"
  ],
  "author": "Ramy Hegab",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "pg": "^8.9.0",
    "axios": "^1.3.4",
    "multer": "^1.4.5-lts.1",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "uuid": "^9.0.0",
    "express-validator": "^7.0.0",
    "pdfkit": "^0.13.0",
    "docx": "^8.5.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^18.15.10",
    "@types/pg": "^8.9.0",
    "typescript": "^5.0.2",
    "ts-node": "^10.9.1",
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0"
  }
}
